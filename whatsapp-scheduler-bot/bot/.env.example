# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=seu_service_role_key_aqui

# Webhook da Edge Function (para processar mensagens recebidas)
SUPABASE_WEBHOOK_URL=https://seu-projeto.supabase.co/functions/v1/webhook-whatsapp

# Mistral AI (para variar mensagens com IA)
MISTRAL_API_KEY=sua_chave_mistral_aqui
MISTRAL_MODEL=devstral-small-2505

# Configurações do Bot
BOT_INSTANCE_NAME=whatsapp_bot
PORT=3000

# Caminho para salvar a sessão do WhatsApp
# Docker: /app/auth_info  |  Local: ./auth_info
AUTH_INFO_PATH=./auth_info

